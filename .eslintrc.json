{
  "extends": ["react-app"],
  "env": {
    "jest": true,
    "es2021": true,
    "browser": true
  },
  "globals": {
    "vi": "readonly",
    "describe": "readonly",
    "it": "readonly",
    "test": "readonly",
    "expect": "readonly",
    "beforeEach": "readonly",
    "afterEach": "readonly",
    "beforeAll": "readonly",
    "afterAll": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": ["warn", { "allow": ["warn", "error", "log"] }],
    "react-hooks/exhaustive-deps": "warn",
    "jsx-a11y/anchor-is-valid": ["error", { "components": ["Link"], "specialLink": ["to", "href"] }],
    "jsx-a11y/click-events-have-key-events": "off",
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/no-noninteractive-tabindex": ["warn", { "allowExpressionValues": true }],
    "jsx-a11y/role-has-required-aria-props": "warn",
    "jsx-a11y/role-supports-aria-props": "warn"
  },
  "overrides": [
    {
      "files": ["**/sections/*.js", "**/components/DiseaseModal.js"],
      "rules": {
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/no-static-element-interactions": "off"
      }
    },
    {
      "files": [
        "**/components/ui/ActionSheet.jsx",
        "**/components/ui/Modal.jsx"
      ],
      "rules": {
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/no-static-element-interactions": "off"
      }
    },
    {
      "files": ["**/*.test.js", "**/*.test.jsx"],
      "rules": {
        "no-script-url": "off"
      }
    }
  ],
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
